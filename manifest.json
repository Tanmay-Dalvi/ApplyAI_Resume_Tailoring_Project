{
  "manifest_version": 3,
  "name": "AI Resume Tailor",
  "version": "1.0.0",
  "description": "Tailor your resume to any LinkedIn job posting",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "AI Resume Tailor"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["src/content/linkedin-scraper.ts"]
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
