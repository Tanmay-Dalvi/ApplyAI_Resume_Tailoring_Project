{
  "manifest_version": 3,
  "name": "ApplyAI",
  "version": "1.0.0",
  "description": "Land your dream role faster by tailoring your resume to any LinkedIn job posting seamlessly.",
  "permissions": [
    "activeTab",
    "storage",
    "sidePanel"
  ],
  "action": {
    "default_title": "Open ApplyAI Side Panel"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "background": {
    "service_worker": "src/background.ts"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["src/content/linkedin-scraper.ts"]
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
